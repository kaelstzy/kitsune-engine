{
  "name": "kitsune-engine",
  "version": "0.3.0",
  "description": "Lightweight JS execution engine - load pages, run JS, get DOM. No browser needed.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules test/basic.test.js",
    "test:new": "node --experimental-vm-modules test/new-api.test.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": ["scraping", "headless", "js-engine", "dom", "lightweight", "kitsune", "puppeteer-alternative"],
  "author": "Kaelz",
  "license": "MIT",
  "dependencies": {
    "htmlparser2": "^9.1.0",
    "css-select": "^5.1.0",
    "dom-serializer": "^2.0.0"
  }
}